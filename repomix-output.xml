  const templatePath = path.join(__dirname, '..', '..', 'templates', 'dev-preferences.md');
  if (!fs.existsSync(templatePath)) error(`Template not found: ${templatePath}`);
  let template = fs.readFileSync(templatePath, 'utf-8');

